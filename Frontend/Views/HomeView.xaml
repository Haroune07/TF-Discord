<UserControl 
    
    x:Class="Frontend.Views.HomeView"
    xmlns:views="clr-namespace:Frontend.Views"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    
    xmlns:local="clr-namespace:Frontend.Views"
    
    xmlns:ViewModels="clr-namespace:Frontend.ViewModels"
    
    mc:Ignorable="d"
    
    d:DesignHeight="720"
    
    d:DesignWidth="1280">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="#1E1F22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72"/>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="235"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#1E1F22" Margin="0,12,0,0">
            <!-- Bouton home — reste intact -->
            <Border Width="48" Height="48" CornerRadius="14" Background="#5865F2" Margin="0,0,0,8">
                <Image Source="/Static/Images/home_button_image.png"
               Stretch="Uniform"
               Width="25"
               Height="25"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"/>
            </Border>
            <Separator Background="#35363C" HorizontalAlignment="Center" Width="32" Margin="0,4,0,12"/>

            <!-- ServerListView en dessous du séparateur -->
            <views:ServerListView DataContext="{Binding ServerList}"/>
        </StackPanel>

        <Grid Grid.Column="1" Background="#2B2D31">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#1E1F22" BorderThickness="0,0,0,1">
                <Button Content="Find or start a conversation"
                        Margin="10,10"
                        Background="#1E1F22"
                        Foreground="#949BA4"
                        BorderThickness="0"/>
            </Border>
            <views:ChannelListView Grid.Row="1" DataContext="{Binding ChannelList}"/>
            <Border Grid.Row="2" Background="#232428" Padding="8,0">
                <Grid VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="32" Height="32">
                            <Ellipse Width="32" Height="32" Fill="#5865F2"/>
                            <Ellipse Width="12"
                                     Height="12"
                                     Fill="#23A55A"
                                     Stroke="#232428"
                                     StrokeThickness="2"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Bottom"
                                     Visibility="{Binding IsUserOnline, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>

                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding User.Username}"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding OnlineStatus}"
                                       Foreground="#B5BAC1"
                                       FontSize="10"/>
                            <TextBlock Text="{Binding MemberSince}"
                                       Foreground="#B5BAC1"
                                       FontSize="10"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Command="{Binding GoToLoginCommand}"
                            Width="33"
                            Margin="181,0,10,0"
                            Background="#313338">
                        <Image Source="/Static/Images/logoutlogo.png" Stretch="Uniform"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="2" Background="#313338">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#1E1F22" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="Friends" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Separator Width="1" Height="24" Background="#3F4147" Margin="16,0"/>
                    <TextBlock Text="Online" Foreground="#B5BAC1" Margin="16,0" VerticalAlignment="Center"/>
                    <TextBlock Text="All" Foreground="#B5BAC1" Margin="16,0" VerticalAlignment="Center"/>
                    <Border Background="#248046" CornerRadius="4" Padding="8,2" Margin="16,0">
                        <TextBlock Text="Add Friend" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Wumpus is waiting for friends." Foreground="#949BA4" FontSize="16"/>
            </StackPanel>
        </Grid>

        <Border Grid.Column="3"
                Background="#313338"
                BorderBrush="#3F4147"
                BorderThickness="1,0,0,0"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Active Now"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,16"/>
                <TextBlock Text="It's quiet for now..."
                           Foreground="#B5BAC1"
                           HorizontalAlignment="Center"
                           Margin="0,40,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>