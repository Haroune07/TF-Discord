<Page x:Class="Frontend.Views.HomeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Frontend.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Home">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/static/images/background.avif" Stretch="UniformToFill"/>
        </Grid.Background>
        <Grid HorizontalAlignment="Left">
            <Grid HorizontalAlignment="Left" Height="Auto" Width="30" Background="#131318" >
                <Border BorderBrush="#151517" BorderThickness="3">

                </Border>

            </Grid>
            <Grid HorizontalAlignment="Left" Width="150" RenderTransformOrigin="0.839,0.507" Margin="30,25,0,0" Background="#1c1d23">
                <Border BorderBrush="Black" BorderThickness="2">

                </Border>
            </Grid>
            <Grid VerticalAlignment="Top" Background="#1c1d23" Height="25" Margin="30,0,0,0">
                <Border BorderBrush="Black" BorderThickness="2">
                    
                </Border>
            </Grid>
        </Grid>
        <Grid VerticalAlignment="Top" Height="25" Margin="180,0,0,0" Background="#1c1d23">
            <Border BorderBrush="Black" BorderThickness="2"/>
        </Grid>
        <Grid VerticalAlignment="Bottom" Height="425" Margin="180,0,120,0" Background="#1c1d23">
            <Border BorderBrush="Black" BorderThickness="2">

            </Border>
        </Grid>
        <Grid HorizontalAlignment="Right" Width="120" Margin="0,25,0,0" Background="#242529">
            <Border BorderBrush="Black" BorderThickness="2">

            </Border>
        </Grid>



    </Grid>
</Page>
