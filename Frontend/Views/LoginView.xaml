<UserControl x:Class="Frontend.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ViewModels="clr-namespace:Frontend.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/static/images/bg_auth.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <!-- Login Panel -->
        <Grid Width="368" Height="331"
          HorizontalAlignment="Center" VerticalAlignment="Center"
          Background="#FF2D314C">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="12*"/>
                <RowDefinition Height="30*"/>
                <RowDefinition Height="30*"/>
                <RowDefinition Height="12*"/>
                <RowDefinition Height="21*"/>
                <RowDefinition Height="36*"/>
                <RowDefinition Height="11*"/>
                <RowDefinition Height="26*"/>
                <RowDefinition Height="35*"/>
                <RowDefinition Height="13*"/>
                <RowDefinition Height="41*"/>
                <RowDefinition Height="7*"/>
                <RowDefinition Height="42*"/>
                <RowDefinition Height="14*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Column="1" Grid.Row="1"
                   Text="Bon Retour!"
                   FontSize="20" Foreground="White"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Height="27" Width="104"/>

            <TextBlock Grid.Column="1" Grid.Row="2"
                   Text="Heureux de vous revoir!"
                   Foreground="White"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Height="16" Width="126"/>

            <TextBlock Grid.Column="1" Grid.Row="4"
                   Text="UserName :"
                   Foreground="White"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Height="16" Width="73"/>

            <TextBox x:Name="UsernameBox"
                 Grid.Column="1" Grid.Row="5"
                 Width="308" Height="28"
                 HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding UserName}"/>

            <TextBlock Grid.Column="1" Grid.Row="7"
                   Text="Mot de passe :"
                   Foreground="White"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Height="15" Width="77"/>

            <PasswordBox x:Name="PasswordBox"
                     Grid.Column="1" Grid.Row="8"
                     Width="308" Height="28"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                         PasswordChanged="PasswordBox_PasswordChanged"/>

            <Border Grid.Column="1" Grid.Row="10"
                Width="308" Height="28"
                CornerRadius="30"
                HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="Se Connecter"
                    Name="LoginButton"
                    BorderThickness="0"
                    Background="#FF5E8BD6" Foreground="White"
                        Command="{Binding LoginCommand}"/>
            </Border>

            <Button Grid.Column="1" Grid.Row="12"
                Content="Créer un compte"
                Background="Transparent" Foreground="#FF5E8BD6"
                FontWeight="Bold" BorderBrush="Transparent"
                HorizontalAlignment="Center" Margin="0,0,0,6" Width="126" Command="{Binding GoToRegisterCommand}"
                />
        </Grid>
    </Grid>
</UserControl>
