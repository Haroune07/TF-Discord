<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Frontend.Views"
             xmlns:ViewModels="clr-namespace:Frontend.ViewModels" 
             xmlns:Converters="clr-namespace:Frontend.Converters"
             x:Class="Frontend.Views.RegisterView"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">

    <Grid>
        <Grid.Resources>
            <Converters:StringToVisibilityConverter x:Key="StringToVisibility"/>
        </Grid.Resources>
        <Grid.Background>
            <ImageBrush ImageSource="/static/images/bg_auth.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <!-- Signup Panel -->
        <Grid Width="368" Height="417"
          HorizontalAlignment="Center" VerticalAlignment="Center"
          Background="#FF2D314C">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="16"/>
                <RowDefinition Height="37"/>
                <RowDefinition Height="27"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="13"/>
                <RowDefinition Height="44"/>
                <RowDefinition Height="11"/>


            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Column="1" Grid.Row="1"
                   Text="Créer un compte"
                   FontSize="20" Foreground="White"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Height="28" Width="148"/>

            <!-- Subtitle -->
            <TextBlock Grid.Column="1" Grid.Row="2"
                   Text="Rejoignez-nous dès aujourd'hui!"
                   Foreground="White"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Width="170" Height="15"/>

            <!-- Username label -->
            <TextBlock Grid.Column="1" Grid.Row="4"
                   Text="Nom d'utilisateur :"
                   Foreground="White"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Height="16" Width="97"/>

            <!-- Username textbox -->
            <TextBox x:Name="UsernameBox"
                 Grid.Column="1" Grid.Row="5"
                 Width="308" Height="28"
                 HorizontalAlignment="Center" VerticalAlignment="Top" MaxLength="100" Text="{Binding UserName}" Margin="0,10,0,0"/>


            <!-- Password label -->
            <TextBlock Grid.Column="1" Grid.Row="7"
                Text="Mot de passe :"
                Foreground="White"
                HorizontalAlignment="Left" VerticalAlignment="Top" Height="16" Width="77"/>

            <PasswordBox x:Name="PasswordBox_confirm"
                 Grid.Column="1" Grid.Row="8"
                 Width="308" Height="28"
                 MaxLength="50"
                 HorizontalAlignment="Center" VerticalAlignment="Center" PasswordChanged="PasswordBox_PasswordChanged"
                         />

            <!-- Confirm password label -->
            <TextBlock Grid.Column="1" Grid.Row="10"
               Foreground="White"
               HorizontalAlignment="Left" VerticalAlignment="Center" Height="16" Width="145"><Run Language="fr-ca" Text="Confirm Password"/></TextBlock>

            <!-- Confirm password box -->
            <PasswordBox x:Name="ConfirmPasswordBox"
                 Grid.Column="1" Grid.Row="11"
                 Width="308" Height="28"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 MaxLength="50"/>

            <TextBlock Grid.Column="1" Grid.Row="12"
               Text="{Binding ErrorMessage}"
               Foreground="#FFFF6B6B"
               HorizontalAlignment="Center" VerticalAlignment="Center"
               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

            <!-- Signup button -->
            <Border Grid.Column="1" Grid.Row="13"
                Width="308" Height="28"
                CornerRadius="10"
                HorizontalAlignment="Center" VerticalAlignment="Center">

                <Button Content="Créer mon compte"
                    Background="#FF5E8BD6" Foreground="White" Command="{Binding RegisterCommand}"/>

            </Border>

            <!-- Back to login -->
            <Button Grid.Column="1" Grid.Row="14"
                Content="Déjà un compte ? Se connecter"
                Background="Transparent" Foreground="#FF5E8BD6"
                FontWeight="Bold" BorderBrush="Transparent"
                HorizontalAlignment="Center"
                Width="232" Margin="0,10,0,-33" Command="{Binding GoToLoginCommand}"/>

        </Grid>
    </Grid>
</UserControl>
