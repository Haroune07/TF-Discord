<UserControl x:Class="Frontend.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Frontend.Views"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/static/images/bg_auth.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <!-- Signup Panel -->
        <Grid Width="368" Height="434"
          HorizontalAlignment="Center" VerticalAlignment="Center"
          Background="#FF2D314C">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="16"/>
                <RowDefinition Height="37"/>
                <RowDefinition Height="27"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="13"/>
                <RowDefinition Height="44"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="43"/>
                <RowDefinition Height="11"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Column="1" Grid.Row="1"
                   Text="Créer un compte"
                   FontSize="20" Foreground="White"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Height="28" Width="148"/>

            <!-- Subtitle -->
            <TextBlock Grid.Column="1" Grid.Row="2"
                   Text="Rejoignez-nous dès aujourd'hui!"
                   Foreground="White"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Width="170"/>

            <!-- Username label -->
            <TextBlock Grid.Column="1" Grid.Row="4"
                   Text="Nom d'utilisateur :"
                   Foreground="White"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Height="16" Width="97"/>

            <!-- Username textbox -->
            <TextBox x:Name="UsernameBox"
                 Grid.Column="1" Grid.Row="5"
                 Width="308" Height="28"
                 HorizontalAlignment="Center" VerticalAlignment="Center" MaxLength="100"/>

            <!-- Email label -->

            <!-- Email textbox -->
            <TextBox x:Name="EmailBox"
                 Grid.Column="1" Grid.Row="8"
                 Width="308" Height="28"
                 HorizontalAlignment="Center" VerticalAlignment="Center" MaxLength="100"/>

            <!-- Password label -->
            <TextBlock Grid.Column="1" Grid.Row="7"
                Text="Mot de passe :"
                Foreground="White"
                HorizontalAlignment="Left" VerticalAlignment="Top" Height="16" Width="77"/>

            <!-- Password box -->
            <PasswordBox x:Name="PasswordBox"
                 Grid.Column="1" Grid.Row="8"
                 Width="308" Height="28"
                 MaxLength="50"
                 HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Confirm password label -->
            <TextBlock Grid.Column="1" Grid.Row="10"
               Text="Confirmer le mot de passe :"
               Foreground="White"
               HorizontalAlignment="Left" VerticalAlignment="Center" Height="16" Width="145"/>

            <!-- Confirm password box -->
            <PasswordBox x:Name="ConfirmPasswordBox"
                 Grid.Column="1" Grid.Row="11"
                 Width="308" Height="28"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 MaxLength="50"/>

            <!-- Signup button -->
            <Border Grid.Column="1" Grid.Row="13"
                Width="308" Height="28"
                CornerRadius="10"
                HorizontalAlignment="Center" VerticalAlignment="Center">

                <Button Content="Créer mon compte"
                    Background="#FF5E8BD6" Foreground="White"/>

            </Border>

            <!-- Back to login -->
            <Button Grid.Column="1" Grid.Row="15"
                Content="Déjà un compte ? Se connecter"
                Background="Transparent" Foreground="#FF5E8BD6"
                FontWeight="Bold" BorderBrush="Transparent"
                HorizontalAlignment="Center"
                Click="BackToLogin_Click" Width="212" VerticalAlignment="Center" Height="34"/>

        </Grid>
    </Grid>
</UserControl>
