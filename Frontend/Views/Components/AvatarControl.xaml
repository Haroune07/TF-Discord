<UserControl x:Class="Frontend.Views.Components.AvatarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Frontend.Views.Components"
             xmlns:components="clr-namespace:Frontend.Views.Components"
             mc:Ignorable="d" 
             d:DesignHeight="32" d:DesignWidth="32">
    <Border CornerRadius="20" Width="32" Height="32" ClipToBounds="True">
        <Grid>
            <Ellipse Fill="#5865F2" Width="32" Height="32"/>
            <components:InitialsView/>
            <Rectangle Width="32" Height="32">
            <Rectangle.Fill>
                        <ImageBrush ImageSource="{Binding AvatarImage}" 
                            Stretch="UniformToFill" 
                            Opacity="{Binding AvatarOpacity}"/>
                    </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Border>
</UserControl>
